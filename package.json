{
  "name": "@holon-run/agentinbox",
  "version": "0.1.0",
  "description": "Local event subscription and delivery service for agents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holon-run/agentinbox.git"
  },
  "homepage": "https://github.com/holon-run/agentinbox#readme",
  "bugs": {
    "url": "https://github.com/holon-run/agentinbox/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agentinbox": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --loader ts-node/esm src/cli.ts",
    "prepack": "npm run build",
    "test": "node --require ts-node/register --test test/*.test.ts"
  },
  "dependencies": {
    "@holon-run/uxc-daemon-client": "^0.13.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/sql.js": "^1.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
